// Prisma schema for URS Pharmacy — Cloud Pharmacy Management System
// Mirrors PROJECT_MAP.md sections 1-14. Every tenant-scoped model carries
// pharmacyId so a single Postgres instance can serve many isolated pharmacies
// (see PROJECT_MAP.md §14 "عزل بيانات كل صيدلية عن الأخرى").

// Using the classic "prisma-client-js" generator (CommonJS, output to
// node_modules/@prisma/client) instead of the new "prisma-client" generator:
// the latter is ESM-first and conflicted with Node 24 + ts-compiled CJS
// output in this project (require(esm) interop errors). This is the
// well-trodden, stable path for a NestJS backend.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Cross-tenant operator account for the "لوحة الإدارة" super-admin panel (section 13) —
/// deliberately NOT a Pharmacy-scoped User, since it must see/manage every pharmacy.
model SystemAdmin {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("system_admins")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Permission {
  VIEW
  CREATE
  UPDATE
  DELETE
  PRINT
  DISCOUNT
  RETURN
  ADJUST_STOCK
}

enum PharmacySubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  READ_ONLY
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum SaleUnit {
  PIECE
  STRIP
  BOX
}

enum BatchStatus {
  ACTIVE
  NEAR_EXPIRY
  EXPIRED
  DEPLETED
}

enum MovementType {
  SALE
  PURCHASE
  RETURN_SALE
  RETURN_PURCHASE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  STOCKTAKE
}

enum PurchaseInvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  CREDIT
}

enum SalesInvoiceStatus {
  HELD
  COMPLETED
  CANCELLED
  PARTIALLY_RETURNED
  FULLY_RETURNED
}

enum GovIntegrationType {
  ZATCA_STANDARD
  ZATCA_SIMPLIFIED
  RASD
}

enum GovIntegrationStatus {
  QUEUED
  ACCEPTED
  REJECTED
  RETRYING
}

// ---------------------------------------------------------------------------
// Tenancy, branches, users, roles (sections 1-3)
// ---------------------------------------------------------------------------

model Pharmacy {
  id                 String                     @id @default(cuid())
  name               String
  logoUrl            String?
  taxNumber          String?
  commercialRegister String?
  invoiceFooterNote  String?
  planName           String                     @default("الباقة الأساسية")
  maxBranches        Int                        @default(1)
  subscriptionStart  DateTime                   @default(now())
  subscriptionEnd    DateTime
  subscriptionStatus PharmacySubscriptionStatus @default(ACTIVE)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  branches   Branch[]
  users      User[]
  roles      Role[]
  categories Category[]
  medications Medication[]
  batches    Batch[]
  suppliers  Supplier[]
  customers  Customer[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  expenses         Expense[]
  auditLogs        AuditLog[]
  govIntegrationLogs GovIntegrationLog[]
  backupRecords      BackupRecord[]
  inventoryMovements InventoryMovement[]

  @@map("pharmacies")
}

model Branch {
  id         String       @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy     @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name       String
  city       String?
  status     BranchStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())

  users              User[]
  batches            Batch[]
  purchaseInvoices   PurchaseInvoice[]
  salesInvoices      SalesInvoice[]
  expenses           Expense[]
  inventoryMovements InventoryMovement[]
  stockLevels        BranchStock[]

  @@index([pharmacyId])
  @@map("branches")
}

/// Default seeded roles: مدير عام (all perms), مدير فرع، كاشير، موظف مخزون، موظف مشتريات (see PROJECT_MAP.md §3)
model Role {
  id          String       @id @default(cuid())
  pharmacyId  String
  pharmacy    Pharmacy     @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name        String
  permissions Permission[]
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  users User[]

  @@unique([pharmacyId, name])
  @@map("roles")
}

model User {
  id           String     @id @default(cuid())
  pharmacyId   String
  pharmacy     Pharmacy   @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  name         String
  email        String     @unique
  passwordHash String?
  status       UserStatus @default(INVITED)
  inviteToken  String?    @unique
  resetToken   String?    @unique
  resetTokenExpiresAt DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())

  auditLogs          AuditLog[]
  createdSales       SalesInvoice[]      @relation("SalesCashier")
  createdPurchases   PurchaseInvoice[]   @relation("PurchaseCreatedBy")
  createdExpenses    Expense[]
  inventoryMovements InventoryMovement[]

  @@index([pharmacyId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Medications, batches, inventory (sections 4-6)
// ---------------------------------------------------------------------------

model Category {
  id         String   @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name       String

  medications Medication[]

  @@unique([pharmacyId, name])
  @@map("categories")
}

model Medication {
  id             String   @id @default(cuid())
  pharmacyId     String
  pharmacy       Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name           String
  scientificName String?
  barcode        String
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  manufacturer   String?
  form           String?
  saleUnit       SaleUnit @default(BOX)
  buyPrice       Decimal  @db.Decimal(12, 2)
  sellPrice      Decimal  @db.Decimal(12, 2)
  taxRate        Decimal  @default(15) @db.Decimal(5, 2)
  minStock       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  batches            Batch[]
  purchaseItems      PurchaseInvoiceItem[]
  salesItems         SalesInvoiceItem[]
  inventoryMovements InventoryMovement[]
  branchStocks       BranchStock[]

  @@unique([pharmacyId, barcode])
  @@index([pharmacyId, name])
  @@map("medications")
}

/// Aggregated current stock per branch+medication — kept in sync by InventoryMovement writes
/// so reads (section 6 "عرض المخزون الحالي لكل فرع") don't need to sum the whole ledger every time.
model BranchStock {
  id           String     @id @default(cuid())
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  quantity     Int        @default(0)
  updatedAt    DateTime   @updatedAt

  @@unique([branchId, medicationId])
  @@map("branch_stocks")
}

model Batch {
  id           String      @id @default(cuid())
  pharmacyId   String
  pharmacy     Pharmacy    @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch      @relation(fields: [branchId], references: [id])
  medicationId String
  medication   Medication  @relation(fields: [medicationId], references: [id])
  supplierId   String?
  supplier     Supplier?   @relation(fields: [supplierId], references: [id])
  batchNumber  String
  quantity     Int
  buyPrice     Decimal     @db.Decimal(12, 2)
  producedAt   DateTime?
  expiresAt    DateTime
  status       BatchStatus @default(ACTIVE)
  createdAt    DateTime    @default(now())

  purchaseItems      PurchaseInvoiceItem[]
  salesItems         SalesInvoiceItem[]
  inventoryMovements InventoryMovement[]

  @@index([pharmacyId, medicationId, expiresAt])
  @@map("batches")
}

/// Append-only ledger — every stock change (sale, purchase, return, transfer,
/// adjustment, stocktake) is recorded here and drives BranchStock (section 6
/// "عرض سجل حركة كل صنف" + "تحديث المخزون تلقائيًا").
model InventoryMovement {
  id            String       @id @default(cuid())
  pharmacyId    String
  pharmacy      Pharmacy     @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch       @relation(fields: [branchId], references: [id])
  medicationId  String
  medication    Medication   @relation(fields: [medicationId], references: [id])
  batchId       String?
  batch         Batch?       @relation(fields: [batchId], references: [id])
  type          MovementType
  quantityDelta Int
  referenceType String?
  referenceId   String?
  note          String?
  createdByUserId String?
  createdByUser   User?      @relation(fields: [createdByUserId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([pharmacyId, medicationId, createdAt])
  @@index([branchId])
  @@map("inventory_movements")
}

// ---------------------------------------------------------------------------
// Purchases & suppliers (section 7)
// ---------------------------------------------------------------------------

model Supplier {
  id         String   @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  createdAt  DateTime @default(now())

  batches          Batch[]
  purchaseInvoices PurchaseInvoice[]

  @@index([pharmacyId])
  @@map("suppliers")
}

model PurchaseInvoice {
  id            String                @id @default(cuid())
  pharmacyId    String
  pharmacy      Pharmacy              @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch                @relation(fields: [branchId], references: [id])
  supplierId    String
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  invoiceNumber String
  date          DateTime              @default(now())
  total         Decimal               @db.Decimal(12, 2)
  paid          Decimal               @default(0) @db.Decimal(12, 2)
  status        PurchaseInvoiceStatus @default(UNPAID)
  createdByUserId String
  createdByUser   User                @relation("PurchaseCreatedBy", fields: [createdByUserId], references: [id])
  createdAt     DateTime              @default(now())

  items   PurchaseInvoiceItem[]
  returns PurchaseReturn[]

  @@unique([pharmacyId, invoiceNumber])
  @@index([pharmacyId, branchId])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  medicationId      String
  medication        Medication      @relation(fields: [medicationId], references: [id])
  batchId           String?
  batch             Batch?          @relation(fields: [batchId], references: [id])
  quantity          Int
  buyPrice          Decimal         @db.Decimal(12, 2)

  @@map("purchase_invoice_items")
}

model PurchaseReturn {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  reason            String
  quantity          Int
  createdAt         DateTime        @default(now())

  @@map("purchase_returns")
}

// ---------------------------------------------------------------------------
// Customers & debts (section 10)
// ---------------------------------------------------------------------------

model Customer {
  id         String   @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  createdAt  DateTime @default(now())

  salesInvoices SalesInvoice[]
  payments      CustomerPayment[]

  @@index([pharmacyId])
  @@map("customers")
}

model CustomerPayment {
  id             String        @id @default(cuid())
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesInvoiceId String?
  salesInvoice   SalesInvoice? @relation(fields: [salesInvoiceId], references: [id])
  amount         Decimal       @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime      @default(now())

  @@map("customer_payments")
}

// ---------------------------------------------------------------------------
// POS, sales & returns (sections 8-9)
// ---------------------------------------------------------------------------

model SalesInvoice {
  id              String             @id @default(cuid())
  pharmacyId      String
  pharmacy        Pharmacy           @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId        String
  branch          Branch             @relation(fields: [branchId], references: [id])
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  cashierUserId   String
  cashierUser     User               @relation("SalesCashier", fields: [cashierUserId], references: [id])
  invoiceNumber   String
  subtotal        Decimal            @db.Decimal(12, 2)
  taxTotal        Decimal            @db.Decimal(12, 2)
  total           Decimal            @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  status          SalesInvoiceStatus @default(COMPLETED)
  cancelReason    String?
  /// ZATCA invoice UUID + hash-chain fields (see PROJECT_MAP.md §2.1 / §12)
  zatcaUuid       String?            @unique
  zatcaPrevHash   String?
  zatcaQrPayload  String?
  createdAt       DateTime           @default(now())

  items           SalesInvoiceItem[]
  returns         SalesReturn[]
  customerPayments CustomerPayment[]
  govIntegrationLogs GovIntegrationLog[]

  @@unique([pharmacyId, invoiceNumber])
  @@index([pharmacyId, branchId, createdAt])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id             String       @id @default(cuid())
  salesInvoiceId String
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  medicationId   String
  medication     Medication   @relation(fields: [medicationId], references: [id])
  batchId        String?
  batch          Batch?       @relation(fields: [batchId], references: [id])
  quantity       Int
  unitPrice      Decimal      @db.Decimal(12, 2)
  discount       Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal      @db.Decimal(12, 2)

  returnItems SalesReturnItem[]

  @@map("sales_invoice_items")
}

model SalesReturn {
  id              String   @id @default(cuid())
  salesInvoiceId  String
  salesInvoice    SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  reason          String
  isFullReturn    Boolean  @default(false)
  createdByUserId String
  createdAt       DateTime @default(now())

  items SalesReturnItem[]

  @@map("sales_returns")
}

model SalesReturnItem {
  id                 String           @id @default(cuid())
  salesReturnId      String
  salesReturn        SalesReturn      @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  salesInvoiceItemId String
  salesInvoiceItem   SalesInvoiceItem @relation(fields: [salesInvoiceItemId], references: [id])
  quantity           Int
  restockedToBatch   Boolean          @default(true)

  @@map("sales_return_items")
}

// ---------------------------------------------------------------------------
// Expenses (section 11 — reports themselves are computed, not stored)
// ---------------------------------------------------------------------------

model Expense {
  id              String   @id @default(cuid())
  pharmacyId      String
  pharmacy        Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id])
  type            String
  amount          Decimal  @db.Decimal(12, 2)
  date            DateTime @default(now())
  note            String?
  createdByUserId String
  createdByUser   User     @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  @@index([pharmacyId, branchId, date])
  @@map("expenses")
}

// ---------------------------------------------------------------------------
// Government integration (section 12)
// ---------------------------------------------------------------------------

/// Independent outbox/queue table for ZATCA + Rasd submissions, so POS never
/// blocks on a slow/broken external connection (PROJECT_MAP.md §12).
model GovIntegrationLog {
  id              String               @id @default(cuid())
  pharmacyId      String
  pharmacy        Pharmacy             @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  salesInvoiceId  String?
  salesInvoice    SalesInvoice?        @relation(fields: [salesInvoiceId], references: [id])
  type            GovIntegrationType
  status          GovIntegrationStatus @default(QUEUED)
  requestPayload  Json?
  responsePayload Json?
  retryCount      Int                  @default(0)
  lastAttemptAt   DateTime?
  createdAt       DateTime             @default(now())

  @@index([pharmacyId, status])
  @@map("gov_integration_logs")
}

// ---------------------------------------------------------------------------
// Audit log & backups (section 14)
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([pharmacyId, createdAt])
  @@map("audit_logs")
}

model BackupRecord {
  id         String   @id @default(cuid())
  pharmacyId String?
  pharmacy   Pharmacy? @relation(fields: [pharmacyId], references: [id])
  sizeBytes  BigInt?
  location   String?
  status     String   @default("completed")
  createdAt  DateTime @default(now())

  @@map("backup_records")
}
